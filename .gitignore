# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
venv/
.venv/
env/

# Секреты и токены — у каждого пользователя копии проекта свои,
# в git не попадают никогда
.env
credentials.json
token.json
*.token.json
*_token.json
*_state.json

# Локальные данные коннекторов: сообщения из Discord/почты/Drive,
# т.е. реальные корпоративные данные — им в репозитории не место
data/
*.db
*.sqlite
*.sqlite3

# Логи проверки подключений — может содержать детали ошибок API (и в
# случае Drive/Gmail — реальные имена файлов пользователя), не для репо.
# Отдельный *.log — потому что часть коннекторов (например drive/sync.py)
# пишет sync_err.log/sync_out.log рядом с собой, а не в общую папку logs/
# (поймано перед первым коммитом: эти два файла чуть не попали в репо).
logs/
*.log

# Сгенерированные отчёты коннекторов (реальные операционные данные) — не для репо
reports/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Бандл готовых учётных данных для бета-тестеров (setup_all.bat) — если он
# вообще существует, то раздаётся отдельно, не через репозиторий. См.
# BETA_DISTRIBUTION.md.
beta_credentials/
STOP_FLAG
