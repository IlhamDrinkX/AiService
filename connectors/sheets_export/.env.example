# Скачанный в Google Cloud Console OAuth client (Desktop app), JSON-файл —
# тот же клиент, что у gmail/drive (см. README), уже скопирован в этот
# коннектор как credentials.json.
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Свой токен (не общий с drive/gmail — у них read-only scope, этому коннектору
# нужна запись). Создастся автоматически при первом входе.
GOOGLE_TOKEN_PATH=./data/token.json
