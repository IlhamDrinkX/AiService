# Скачанный в Google Cloud Console OAuth client (Desktop app), JSON-файл
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Куда сохранить токен после первого входа (создастся автоматически)
GOOGLE_TOKEN_PATH=./data/token.json

# Путь к файлу SQLite (создастся автоматически)
DB_PATH=./data/gmail.db

# Читать ли спам/корзину (по умолчанию нет)
INCLUDE_SPAM_TRASH=false

# Максимальная длина тела письма, символов (защита от гигантских писем)
BODY_MAX_CHARS=20000
