# Куда кэшировать полученный JWT, чтобы не логиниться при каждом запуске.
# Токен живёт ~30 дней; при 401/403 client.py логинится заново автоматически.
FIBBEE_TOKEN_PATH=./fibbee_token.json

DB_PATH=./data/fibbee.db
