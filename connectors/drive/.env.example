# Можно указать на тот же credentials.json, что и для Gmail (тот же OAuth
# клиент, скоупы запрашиваются отдельно) — просто скопируй файл в эту папку.
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Свой токен для Drive (отдельный от Gmail, т.к. другой scope)
GOOGLE_TOKEN_PATH=./data/token.json

# Путь к файлу SQLite
DB_PATH=./data/drive.db

# Максимальная длина извлекаемого текста на файл, символов. 0 = без
# ограничения (документы читаются целиком, независимо от числа страниц).
# Ставь ненулевое значение только если сознательно хочешь урезать текст
# (например, для контроля размера контекста при последующей обработке ИИ).
TEXT_MAX_CHARS=0

# Не скачивать содержимое файлов крупнее этого размера (метаданные всё равно сохранятся)
MAX_FILE_SIZE_MB=25

# Таймаут одного сетевого запроса, секунд. Увеличь, если сеть медленная,
# но не сеть просто нестабильна (тогда лучше не трогать — retry-логика
# сама справится быстрее с коротким таймаутом)
REQUEST_TIMEOUT_SECONDS=60
