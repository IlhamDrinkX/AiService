# Токен бота из Developer Portal → Bot → Reset Token
DISCORD_BOT_TOKEN=your-bot-token-here

# Путь к файлу SQLite (создастся автоматически)
DB_PATH=./data/discord.db

# Сколько последних сообщений забирать при первом запуске на канал/тред
BACKFILL_LIMIT=200

# Сколько сообщений забирать при первом запуске из каждого архивного треда
ARCHIVED_THREAD_LIMIT=100

# Читать ли треды и форум-посты (true/false)
INCLUDE_THREADS=true

# Читать ли архивные (закрытые) треды и форум-посты, не только активные
INCLUDE_ARCHIVED_THREADS=true

# Читать ли форум-каналы (посты в них — это тоже треды)
INCLUDE_FORUM=true

# Читать ли текстовый чат внутри голосовых каналов
INCLUDE_VOICE_TEXT=true

# Список ID каналов через запятую, которые читаем. Пусто = все каналы, куда у
# бота есть доступ. Для тредов/форум-постов достаточно указать ID родительского
# канала — все его треды/посты подхватятся автоматически. Включить режим
# разработчика в Discord (Настройки → Расширенные) и через ПКМ на канале →
# "Копировать ID канала".
CHANNEL_IDS=
