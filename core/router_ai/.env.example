# Скопируй в .env и вставь свой ключ. .env — в .gitignore, не коммитится.
OPENROUTER_API_KEY=

# Опционально. Меняются, если/когда переходим на локальную LLM
# (OpenAI-совместимый сервер: Ollama/vLLM/LM Studio) — тогда сюда пишется
# адрес локального сервера, а router_ai_client не меняется вообще.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Не обязательны для работы, но OpenRouter учитывает их в рейтингах моделей.
OPENROUTER_APP_TITLE=AI Service System
OPENROUTER_APP_URL=

# Ключ Google Generative Language API (корпоративный Gemini, бесплатный тир) —
# нужен уровням, у которых в models.yaml стоит provider: gemini_direct
# (сейчас nano и flash). Взять на aistudio.google.com -> Get API key,
# привязав к нужному GCP-проекту. Без биллинга — работает и так, в рамках
# бесплатной квоты запросов/минуту.
GEMINI_API_KEY=
